<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="P7_Analisis04.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30,0"
            VerticalOptions="Center">

            <Label
                Text="🇸🇻 Bandera de El Salvador"
                FontSize="32"
                HorizontalOptions="Center"
                FontAttributes="Bold" />

            <!-- Bandera de El Salvador -->
            <Frame
                BorderColor="Black"
                CornerRadius="5"
                Padding="0"
                Margin="0,20"
                HeightRequest="300"
                WidthRequest="500"
                HorizontalOptions="Center">

                <Grid>
                    <!-- Franja Azul Superior -->
                    <BoxView
                        Color="#0047AB"
                        HeightRequest="100"
                        VerticalOptions="Start" />

                    <!-- Franja Blanca Central -->
                    <BoxView
                        Color="White"
                        HeightRequest="100"
                        VerticalOptions="Center" />

                    <!-- Franja Azul Inferior -->
                    <BoxView
                        Color="#0047AB"
                        HeightRequest="100"
                        VerticalOptions="End" />

                    <!-- Texto "Dios Unión Libertad" -->
                    <Label
                        Text="DIOS UNIÓN LIBERTAD"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#0047AB"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Margin="0,-30,0,0" />

                    <!-- Escudo Nacional (representado con formas) -->
                    <Grid
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Margin="0,20,0,0">

                        <!-- Círculo exterior dorado -->
                        <BoxView
                            Color="#FFD700"
                            WidthRequest="60"
                            HeightRequest="60"
                            CornerRadius="30" />

                        <!-- Círculo interior azul -->
                        <BoxView
                            Color="#0047AB"
                            WidthRequest="50"
                            HeightRequest="50"
                            CornerRadius="25"
                            Margin="5" />

                        <!-- Triángulo interior (representado con una etiqueta) -->
                        <Label
                            Text="▲"
                            FontSize="35"
                            TextColor="#FFD700"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Grid>
                </Grid>
            </Frame>

            <!-- Demostración de colores con BoxView -->
            <Label
                Text="Colores de la Bandera"
                FontSize="24"
                HorizontalOptions="Center"
                Margin="0,20,0,10" />

            <Grid
                ColumnDefinitions="*,*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="10"
                RowSpacing="10">

                <!-- Azul -->
                <Frame
                    Grid.Column="0"
                    Grid.Row="0"
                    BorderColor="Gray"
                    CornerRadius="10"
                    Padding="0"
                    HeightRequest="80">
                    <VerticalStackLayout>
                        <BoxView
                            Color="#0047AB"
                            HeightRequest="40" />
                        <Label
                            Text="Azul #0047AB"
                            FontSize="12"
                            HorizontalOptions="Center"
                            Margin="0,5" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Blanco -->
                <Frame
                    Grid.Column="1"
                    Grid.Row="0"
                    BorderColor="Gray"
                    CornerRadius="10"
                    Padding="0"
                    HeightRequest="80">
                    <VerticalStackLayout>
                        <BoxView
                            Color="White"
                            HeightRequest="40" />
                        <Label
                            Text="Blanco #FFFFFF"
                            FontSize="12"
                            HorizontalOptions="Center"
                            Margin="0,5" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Dorado -->
                <Frame
                    Grid.Column="2"
                    Grid.Row="0"
                    BorderColor="Gray"
                    CornerRadius="10"
                    Padding="0"
                    HeightRequest="80">
                    <VerticalStackLayout>
                        <BoxView
                            Color="#FFD700"
                            HeightRequest="40" />
                        <Label
                            Text="Dorado #FFD700"
                            FontSize="12"
                            HorizontalOptions="Center"
                            Margin="0,5" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Ejemplo de degradado con BoxView -->
                <Frame
                    Grid.Column="0"
                    Grid.Row="1"
                    Grid.ColumnSpan="3"
                    BorderColor="Gray"
                    CornerRadius="10"
                    Padding="0"
                    HeightRequest="60">
                    <Grid>
                        <BoxView
                            Color="#0047AB"
                            HeightRequest="60" />
                        <BoxView
                            Color="White"
                            HeightRequest="60"
                            Opacity="0.3" />
                        <Label
                            Text="Azul con Transparencia"
                            TextColor="White"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Grid>
                </Frame>
            </Grid>

            <!-- Información adicional -->
            <Frame
                BackgroundColor="#F0F0F0"
                CornerRadius="10"
                Padding="15"
                Margin="0,20">
                <VerticalStackLayout Spacing="5">
                    <Label
                        Text="📌 Datos de la Bandera"
                        FontAttributes="Bold"
                        FontSize="16" />
                    <Label Text="• Adoptada: 17 de mayo de 1912" FontSize="14" />
                    <Label Text="• Colores: Azul, Blanco y Dorado" FontSize="14" />
                    <Label Text="• Lema: DIOS UNIÓN LIBERTAD" FontSize="14" />
                    <Label Text="• Tamaño: 3:2 (Largo:Ancho)" FontSize="14" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
